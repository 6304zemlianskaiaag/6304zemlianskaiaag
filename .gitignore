cat > .gitignore << 'EOF'
# Виртуальное окружение
.project_venv/
venv/
env/
ENV/

# Python кэш
__pycache__/
*.pyc
*.pyo
*.pyd

# Скачанные изображения и данные
paintings/
*.jpg
*.jpeg
*.png
*.json

# Файлы конфигурации (личные, не в репозиторий)
.flake8
.tox
.coverage

# Настройки редакторов
.vscode/
.idea/
*.swp
*.swo

# Системные файлы
.DS_Store
Thumbs.db
EOF".flake8" 
